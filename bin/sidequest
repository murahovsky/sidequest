#!/usr/bin/env python3
"""sidequest — Claude Code with live spinner facts.

One binary does everything. On first run it installs the Sidequest plugin
(marketplace + plugin, via the claude CLI) and opens a session that finishes
setup; after that it is a transparent wrapper around `claude` that swaps a
fresh fact into the spinner line every few seconds.

Why a wrapper: Claude Code samples its spinner verb ONCE per user turn, so
settings-based rotation can never change the visible fact mid-turn. This
fixes it at the display layer: the verb in settings is a unique 64-column
sentinel token and, sitting on a pty between the terminal and Claude Code,
the wrapper substitutes that token in the output stream with the current
fact.

Ink (Claude Code's renderer) repaints the verb both as whole lines and as
positioned partial slices (ESC[nG + a few chars), so a literal replace is
not enough. The filter tracks the cursor column, learns the sentinel's
screen position from a full paint (the anchor), and substitutes only runs
that match the sentinel at that exact alignment — long enough that ordinary
text which happens to coincide with a sentinel character (the F of "Fable")
is never touched.

Usage: sidequest [any claude args...]
Env:   SIDEQUEST_INTERVAL  seconds between facts (default 3)
       SIDEQUEST_CMD       child command (default: claude; for tests)
       SIDEQUEST_REPO      plugin marketplace source (default: murahovsky/sidequest)
"""
import fcntl
import json
import os
import pty
import random
import select
import signal
import subprocess
import sys
import tempfile
import termios
import time
import tty
import unicodedata

# 64 ascii columns, printed by Claude Code itself. APERIODIC on purpose: the
# digits make every >=14-char slice identify its own offset, so a repaint of
# the verb's tail can never be mistaken for the verb's start.
SENTINEL = "SIDEQUESTFACT0SIDEQUESTFACT1SIDEQUESTFACT2SIDEQUESTFACT3SIDEQUES"
SENT_B = SENTINEL.encode()
WIDTH = 64
# A run must match the sentinel from index 0 for at least ANCHOR_RUN chars to
# (re)teach us where the sentinel sits on screen (column, row and visible
# span). On that exact row, at that alignment, single-character repaints are
# trusted too — Claude Code's shimmer repaints the verb in 1-3 char slices.
# A run may flush mid-chunk once it reaches SURE_RUN; shorter anchored
# fragments wait to see what breaks them: broken by ordinary text painted
# into the zone, the anchor is considered overwritten and dropped.
ANCHOR_RUN = 16
SURE_RUN = 6
HOME = os.path.expanduser("~")
# Follow the instance: with CLAUDE_CONFIG_DIR set, settings/plugins/data all
# live there — writing to ~/.claude would feed a different Claude.
CONFIG_DIR = os.environ.get("CLAUDE_CONFIG_DIR", os.path.join(HOME, ".claude"))
DATA_DIR = os.environ.get("SIDEQUEST_HOME", os.path.join(CONFIG_DIR, "sidequest"))
SETTINGS_PATH = os.environ.get("SIDEQUEST_SETTINGS", os.path.join(CONFIG_DIR, "settings.json"))
INTERVAL = float(os.environ.get("SIDEQUEST_INTERVAL", "3"))
CHILD = os.environ.get("SIDEQUEST_CMD", "claude")
REPO = os.environ.get("SIDEQUEST_REPO", "murahovsky/sidequest")
MARKETPLACE = "sidequest"
PLUGIN = "sidequest"
MARKER_PATH = os.path.join(DATA_DIR, "installed")
IDLE_LINE = "Sidequest: facts will appear here once you pick a topic"

def load_json(path, default):
    try:
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    except Exception:  # noqa: BLE001
        return default


def atomic_write(path, obj):
    d = os.path.dirname(path)
    os.makedirs(d, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=d, prefix=".sidequest-")
    with os.fdopen(fd, "w", encoding="utf-8") as f:
        json.dump(obj, f, ensure_ascii=False, indent=2)
        f.write("\n")
    os.replace(tmp, path)


def claude_cli(*args):
    return subprocess.run(
        [CHILD, *args], stdin=subprocess.DEVNULL, capture_output=True, text=True
    )


def ensure_installed():
    """First run only: register the marketplace and install the plugin."""
    if os.path.exists(MARKER_PATH):
        return
    try:
        if claude_cli("--version").returncode != 0:
            raise OSError
    except OSError:
        sys.exit("sidequest: Claude Code CLI not found — install it first: https://code.claude.com")
    print("Sidequest: first run — installing the plugin…")
    for step in (("plugin", "marketplace", "add", REPO), ("plugin", "install", f"{PLUGIN}@{MARKETPLACE}")):
        r = claude_cli(*step)
        out = f"{r.stdout}{r.stderr}"
        if r.returncode != 0 and "already" not in out.lower():
            sys.exit(f"sidequest: `claude {' '.join(step)}` failed:\n{out.strip()}")
    os.makedirs(DATA_DIR, exist_ok=True)
    with open(MARKER_PATH, "w", encoding="utf-8") as f:
        f.write("1\n")
    print("✓ Sidequest installed — pick your topic in the session that opens.")
    print("  Later: /sidequest:topic <topic> changes it, /sidequest:off turns it off.")
    print("  Tip: alias claude=sidequest to make live facts the default.\n")


def set_sentinel():
    s = load_json(SETTINGS_PATH, {})
    if not isinstance(s, dict):
        return
    s["spinnerVerbs"] = {"mode": "replace", "verbs": [SENTINEL]}
    atomic_write(SETTINGS_PATH, s)


def unset_sentinel():
    """On exit, swap the sentinel back to plain fact verbs (per-turn mode)."""
    s = load_json(SETTINGS_PATH, None)
    if not isinstance(s, dict):
        return
    v = s.get("spinnerVerbs")
    if not (isinstance(v, dict) and v.get("verbs") == [SENTINEL]):
        return
    doc = load_json(os.path.join(DATA_DIR, "facts.json"), {})
    raw = doc.get("facts") if isinstance(doc, dict) else None
    pool = [x.strip() for x in raw if isinstance(x, str) and x.strip()] if isinstance(raw, list) else []
    pool = [x for x in pool if len(x) <= 60]
    if pool:
        s["spinnerVerbs"] = {"mode": "replace", "verbs": [f"{x} │" for x in random.sample(pool, min(30, len(pool)))]}
    else:
        s.pop("spinnerVerbs", None)
    atomic_write(SETTINGS_PATH, s)


class Facts:
    def __init__(self):
        self.mtime = None
        self.pool = []
        self.queue = []
        self.banner = None
        self.banner_left = 2  # facts shown under the banner before it retires
        self.banner_done = False
        self.warm = []   # rotating "loading" teasers while facts are generating
        self.warm_i = 0

    def refresh(self):
        path = os.path.join(DATA_DIR, "facts.json")
        try:
            m = os.stat(path).st_mtime
        except OSError:
            m = 0
        if m != self.mtime:
            self.mtime = m
            doc = load_json(path, {})
            raw = doc.get("facts") if isinstance(doc, dict) else None
            if not isinstance(raw, list):
                raw = []
            pool = [" ".join(x.split()) for x in raw if isinstance(x, str) and x.strip()]
            self.pool = [x for x in pool if len(x) <= WIDTH]  # longer ones would truncate mid-word
            self.queue = []
        if not self.banner_done and self.banner is None:
            # warmup stores the launch banner in state.json the moment the
            # user picks a topic — before any facts exist
            st = load_json(os.path.join(DATA_DIR, "state.json"), {})
            b = st.get("banner") if isinstance(st, dict) else None
            if isinstance(b, str) and b.strip():
                self.banner = " ".join(b.split())
            w = st.get("warmup_lines") if isinstance(st, dict) else None
            if isinstance(w, list):
                self.warm = [" ".join(x.split())[:WIDTH] for x in w if isinstance(x, str) and x.strip()]

    def _retire_banner(self):
        self.banner_done = True
        self.banner = None
        p = os.path.join(DATA_DIR, "state.json")
        st = load_json(p, None)
        if isinstance(st, dict) and ("banner" in st or "warmup_lines" in st):
            st.pop("banner", None)
            st.pop("warmup_lines", None)
            try:
                atomic_write(p, st)
            except OSError:
                pass
        self.warm = []

    def next_line(self):
        self.refresh()
        if self.banner and not self.banner_done:
            if not self.pool:
                # generation still running — rotate the launch line with the
                # "loading" teasers so the spinner is already alive
                seq = [self.banner] + self.warm
                line = seq[self.warm_i % len(seq)]
                self.warm_i += 1
                return line
            if self.banner_left > 0:
                self.banner_left -= 1
                return self.banner
            self._retire_banner()
        if not self.pool:
            return IDLE_LINE
        if not self.queue:
            self.queue = random.sample(self.pool, len(self.pool))
        return self.queue.pop()


def char_width(ch):
    """Terminal columns one character occupies (CJK and fullwidth take two)."""
    if isinstance(ch, (bytes, bytearray)):
        try:
            ch = ch.decode("utf-8")
        except UnicodeDecodeError:
            return 1
    return 2 if unicodedata.east_asian_width(ch) in ("F", "W") else 1


def pad_cells(text):
    """Render a fact into WIDTH terminal cells; returns (cells, used) where
    used is the visible length. A wide char occupies two cells (the second
    one empty), so substituting cell-for-column never changes line width."""
    cells = []
    for ch in " ".join(text.split()):
        w = char_width(ch)
        if len(cells) + w > WIDTH:
            break
        cells.append(ch)
        if w == 2:
            cells.append("")
    used = len(cells)
    while len(cells) < WIDTH:
        cells.append(" ")
    return cells, used


class SpinnerFilter:
    """Column- and row-tracking stream filter substituting sentinel paints.

    A run matching the sentinel from its start for ANCHOR_RUN+ chars is an
    anchor paint: it is substituted and records where the sentinel lives
    (column, row, visible span — narrow terminals truncate the verb). On the
    anchor row, runs matching at that alignment substitute at any length,
    which is what Claude Code's shimmer needs (it repaints 1-3 char slices).
    SGRs inside a run are buffered and replayed over the fact text.

    Ordinary text is protected twice over: off the anchor row nothing shorter
    than ANCHOR_RUN is ever touched, and on the anchor row the first ordinary
    character painted into the zone (a run broken by a non-matching printable,
    or a stray one) drops the anchor until the next full paint re-learns it.
    """

    def __init__(self, facts):
        self.facts = facts
        self.cells, self.flen = pad_cells(facts.next_line())
        self.last_swap = time.monotonic()
        self.col = None      # 1-based cursor column; None until CR/escape tells us
        self.row = 0         # cursor row, relative units (origin arbitrary)
        self.anchor = None   # screen column of sentinel index 0, once seen
        self.anchor_row = None
        self.span = WIDTH    # chars of the sentinel actually painted last time
        self.hold = b""      # incomplete trailing escape / utf-8 char
        self.pend = bytearray()  # candidate sentinel run: original bytes incl. buffered SGRs
        self.pend_chars = 0      # matched sentinel chars in pend (excludes SGR bytes)
        self.cands = []          # sentinel start-indexes still consistent with the run
        self.anch_c = None       # the candidate matching the learned anchor alignment

    def maybe_swap(self):
        if time.monotonic() - self.last_swap >= INTERVAL:
            self.cells, self.flen = pad_cells(self.facts.next_line())
            self.last_swap = time.monotonic()

    def feed(self, data):
        d = self.hold + data
        self.hold = b""
        cut = self._utf8_tail(d)
        tail = b""
        if cut:
            tail, d = d[-cut:], d[:-cut]
        out = self._walk(d)  # may set self.hold to an incomplete escape tail
        self.hold += tail
        return out

    def idle_flush(self):
        """The stream went quiet with a fragment buffered: resolve it now."""
        out = bytearray()
        self._flush(out)
        return bytes(out)

    def finish(self):
        """Flush whatever is still buffered (child exited mid-paint)."""
        out = bytearray()
        self._flush(out)
        out += self.hold
        self.hold = b""
        return bytes(out)

    @staticmethod
    def _utf8_tail(d):
        for back in range(1, min(4, len(d)) + 1):
            b = d[-back]
            if b < 0x80:
                return 0
            if b >= 0xC0:  # leading byte: complete if its char fits
                need = 2 if b < 0xE0 else 3 if b < 0xF0 else 4
                return back if need > back else 0
        return 0

    def _in_zone(self):
        return (
            self.anchor is not None
            and self.row == self.anchor_row
            and self.col is not None
            and self.anchor <= self.col < self.anchor + self.span
        )

    def _choice(self, definitive):
        L = self.pend_chars
        # The learned alignment is a strong prior — prefer it over re-anchoring,
        # or a tail slice that happens to look like a start would move the anchor.
        if self.anch_c is not None and self.anch_c in self.cands and (definitive or L >= SURE_RUN):
            return self.anch_c
        if 0 in self.cands and L >= ANCHOR_RUN:
            return 0
        return None

    def _flush(self, out, poison=False):
        if not self.pend:
            return
        chosen = None if poison else self._choice(definitive=True)
        if poison:
            self.anchor = None  # the zone was overwritten by ordinary content
        if chosen == 0 and self.pend_chars >= ANCHOR_RUN:
            if self.col is not None:
                self.anchor = self.col - self.pend_chars
                self.anchor_row = self.row
                self.span = self.pend_chars  # truncated terminals paint fewer than 64
            self.maybe_swap()  # a fresh frame: the consistent moment to advance
        if chosen is not None:
            out += self._sub_pend(chosen)
            if time.monotonic() - self.last_swap >= INTERVAL and self.anchor is not None:
                # No full repaint arrived in time (the desktop app repaints only
                # deltas) — advance the fact and repaint the zone ourselves,
                # parking the cursor back where it was. The whole zone is
                # rewritten (fact + pad spaces), the suffix stays untouched.
                self.cells, self.flen = pad_cells(self.facts.next_line())
                self.last_swap = time.monotonic()
                out += b"\x1b7\x1b[%dG" % self.anchor
                out += "".join(self.cells[: self.span]).encode("utf-8")
                out += b"\x1b8"
        else:
            out += bytes(self.pend)
        self.pend = bytearray()
        self.pend_chars = 0
        self.cands = []
        self.anch_c = None

    def _sub_pend(self, c):
        """Replace matched chars with fact cells (pad spaces past the fact's
        end), keeping buffered SGRs in place so the shimmer plays over the
        fact. Cell-for-column, always: Ink diffs against what it painted, and
        any column we shift or skip turns its later repaints into debris."""
        res = bytearray()
        i, k = 0, 0
        while i < len(self.pend):
            if self.pend[i] == 0x1B:
                j, _ = self._esc_end(self.pend, i)
                res += self.pend[i:j]
                i = j
            else:
                res += self.cells[c + k].encode("utf-8")
                k += 1
                i += 1
        return res

    def _start_run(self, b):
        cands = []
        anch_c = None
        if self._in_zone() and b == SENT_B[self.col - self.anchor]:
            anch_c = self.col - self.anchor
            cands.append(anch_c)
        if b == SENT_B[0] and 0 not in cands:
            cands.append(0)
        if not cands:
            return False
        self.pend.append(b)
        self.pend_chars = 1
        self.cands = cands
        self.anch_c = anch_c
        if self.col is not None:
            self.col += 1
        return True

    def _walk(self, d):
        out = bytearray()
        i, n = 0, len(d)
        while i < n:
            b = d[i]
            if b == 0x1B:
                j, complete = self._esc_end(d, i)
                if complete and self.pend and d[i + 1 : i + 2] == b"[" and d[j - 1 : j] == b"m":
                    # SGR colors don't move the cursor: keep them inside the run,
                    # or the shimmer painted over the verb would split every
                    # frame into fragments
                    self.pend += d[i:j]
                    i = j
                    continue
                self._flush(out)
                if not complete and n - i <= 8192:
                    self.hold = bytes(d[i:])  # escape split across chunks
                    return bytes(out)
                if complete:
                    self._apply_esc(d[i:j])
                out += d[i:j]
                i = j
            elif 0x20 <= b < 0x7F:
                if self.pend:
                    L = self.pend_chars
                    alive = [c for c in self.cands if c + L < WIDTH and b == SENT_B[c + L]]
                    if alive:
                        self.cands = alive
                        self.pend.append(b)
                        self.pend_chars += 1
                        if self.col is not None:
                            self.col += 1
                        i += 1
                        continue
                    # a run broken by ordinary text painted into the zone means
                    # the sentinel row now shows something else (space = clearing,
                    # which is neutral)
                    self._flush(out, poison=self._in_zone() and b != 0x20)
                if not self._start_run(b):
                    if self._in_zone() and b != 0x20:
                        self.anchor = None  # ordinary char over the sentinel zone
                    out.append(b)
                    if self.col is not None:
                        self.col += 1
                i += 1
            elif b == 0x0D:  # CR
                self._flush(out)
                self.col = 1
                out.append(b)
                i += 1
            elif b == 0x0A:  # LF
                self._flush(out)
                self.row += 1
                out.append(b)
                i += 1
            elif b == 0x08:  # BS
                self._flush(out)
                if self.col is not None and self.col > 1:
                    self.col -= 1
                out.append(b)
                i += 1
            elif b >= 0xC0:  # utf-8 lead byte: copy the whole character
                self._flush(out)
                ln = 2 if b < 0xE0 else 3 if b < 0xF0 else 4
                ch = d[i : i + ln]
                out += ch
                if self.col is not None:
                    self.col += char_width(ch)
                i += ln
            else:  # BEL, other controls, stray continuation bytes
                self._flush(out)
                out.append(b)
                i += 1
        # A run that already qualifies can be painted now; an ambiguous short
        # fragment stays buffered until we see what breaks it.
        if self.pend and self._choice(definitive=False) is not None:
            self._flush(out)
        return bytes(out)

    @staticmethod
    def _esc_end(d, i):
        """Returns (end_index, complete) for the escape sequence at d[i:]."""
        n = len(d)
        if i + 1 >= n:
            return n, False
        kind = d[i + 1]
        if kind == 0x5B:  # CSI: parameters until a final byte 0x40-0x7E
            j = i + 2
            while j < n:
                if 0x40 <= d[j] <= 0x7E:
                    return j + 1, True
                j += 1
            return n, False
        if kind in b"]PX^_":  # OSC/DCS/SOS/PM/APC: string until BEL or ST
            bel = d.find(b"\x07", i + 2)
            st = d.find(b"\x1b\\", i + 2)
            ends = [e for e in (bel + 1 if bel != -1 else 0, st + 2 if st != -1 else 0) if e]
            if ends:
                return min(ends), True
            return n, False
        return i + 2, True  # two-byte escape

    def _apply_esc(self, seq):
        if len(seq) < 3 or seq[1:2] != b"[":
            return
        final = seq[-1:]
        body = seq[2:-1].decode("ascii", "replace")
        try:
            if final == b"G":
                self.col = int(body or "1")
            elif final in (b"H", b"f"):
                parts = body.split(";")
                self.row = int(parts[0]) if parts and parts[0] else 1
                self.col = int(parts[1]) if len(parts) > 1 and parts[1] else 1
                self.anchor = None  # absolute jump: a new coordinate space
            elif final == b"C":
                if self.col is not None:
                    self.col += int(body or "1")
            elif final == b"D":
                if self.col is not None:
                    self.col = max(1, self.col - int(body or "1"))
            elif final == b"A":
                self.row -= int(body or "1")
            elif final == b"B":
                self.row += int(body or "1")
            elif final == b"E":
                self.row += int(body or "1")
                self.col = 1
            elif final == b"F":
                self.row -= int(body or "1")
                self.col = 1
            elif final == b"d":
                self.row = int(body or "1")
            elif final in (b"S", b"T") or (final == b"J" and body in ("2", "3")):
                self.anchor = None  # scroll / clear: row correspondence broken
        except ValueError:
            self.col = None


def main():
    ensure_installed()
    child_args = sys.argv[1:]
    # Claude can't speak first, so a fresh setup needs one user message baked in.
    if not child_args and sys.stdin.isatty() and not os.path.exists(os.path.join(DATA_DIR, "facts.json")):
        child_args = ["Set up Sidequest"]

    os.environ["SIDEQUEST_PTY"] = "1"
    set_sentinel()
    pid, master = pty.fork()
    if pid == 0:
        try:
            os.execvp(CHILD, [CHILD] + child_args)
        except OSError as e:
            print(f"sidequest: cannot exec {CHILD}: {e}", file=sys.stderr)
            os._exit(127)

    def push_winsize(*_):
        try:
            size = fcntl.ioctl(0, termios.TIOCGWINSZ, b"\0" * 8)
            fcntl.ioctl(master, termios.TIOCSWINSZ, size)
        except OSError:
            pass

    interactive = sys.stdin.isatty()
    old_attrs = None
    if interactive:
        push_winsize()
        signal.signal(signal.SIGWINCH, push_winsize)
        try:
            old_attrs = termios.tcgetattr(0)
            tty.setraw(0)
        except termios.error:
            old_attrs = None

    filt = SpinnerFilter(Facts())
    dbg = os.environ.get("SIDEQUEST_DEBUG")
    status = 0
    try:
        while True:
            try:
                ready, _, _ = select.select([0, master], [], [], 0.25)
            except InterruptedError:
                continue
            if not ready and filt.pend:
                os.write(1, filt.idle_flush())
            if 0 in ready:
                try:
                    data = os.read(0, 65536)
                except OSError:
                    data = b""
                if data:
                    os.write(master, data)
            if master in ready:
                try:
                    data = os.read(master, 65536)
                except OSError:
                    data = b""
                if not data:
                    break
                if dbg:
                    with open(dbg, "ab") as df:
                        df.write(b"\n<<CHUNK %d>>" % int(time.monotonic() * 1000))
                        df.write(data)
                os.write(1, filt.feed(data))
        os.write(1, filt.finish())
    finally:
        if old_attrs is not None:
            termios.tcsetattr(0, termios.TCSADRAIN, old_attrs)
        unset_sentinel()
    try:
        _, st = os.waitpid(pid, 0)
        status = os.waitstatus_to_exitcode(st)
    except ChildProcessError:
        status = 0
    sys.exit(status)


if __name__ == "__main__":
    main()
